generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  ADMIN
  MANAGER
  CHEF
  WAITER
  DELIVERY
}

enum OrderStatus {
  NEW_ORDER
  ACCEPTED
  PREPARING
  READY
  SERVED
  COMPLETED
  CANCELLED
}

model User {
  id            String    @id @default(uuid())
  phone         String?   @unique
  email         String?   @unique
  password      String
  name          String?
  role          Role      @default(CUSTOMER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  addresses     Address[]
  orders        Order[]
  reviews       Review[]
  favorites     Favorite[]
}

model Restaurant {
  id          String   @id @default(uuid())
  name        String
  address     String
  phone       String
  email       String
  logo        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tables      Table[]
  categories  MenuCategory[]
  staff       Staff[]
  printers    Printer[]
}

model Table {
  id           String     @id @default(uuid())
  tableNumber  String
  capacity     Int
  status       String     @default("AVAILABLE") // AVAILABLE, OCCUPIED, RESERVED
  qrCode       String?    // URL or Data for the QR
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  orders       Order[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([restaurantId, tableNumber])
}

model Address {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  type          String   // Home, Office, Other
  addressLine1  String
  addressLine2  String?
  city          String
  state         String
  zipCode       String
  isDefault     Boolean  @default(false)
  orders        Order[]
}

model MenuCategory {
  id           String     @id @default(uuid())
  name         String
  image        String?
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  items        MenuItem[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model MenuItem {
  id              String         @id @default(uuid())
  name            String
  description     String?
  price           Decimal
  image           String?
  isVeg           Boolean        @default(true)
  preparationTime Int?           // in minutes
  availability    Boolean        @default(true)
  categoryId      String
  category        MenuCategory   @relation(fields: [categoryId], references: [id])
  addons          Addon[]
  orderItems      OrderItem[]
  favorites       Favorite[]
  reviews         Review[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Addon {
  id         String   @id @default(uuid())
  name       String
  price      Decimal
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
}

model Order {
  id             String           @id @default(uuid())
  orderNumber    Int              @default(autoincrement())
  userId         String?
  user           User?            @relation(fields: [userId], references: [id])
  tableId        String?
  table          Table?           @relation(fields: [tableId], references: [id])
  status         OrderStatus      @default(NEW_ORDER)
  totalPrice     Decimal
  notes          String?
  deliveryType   String           @default("DINE_IN") // DINE_IN, DELIVERY, PICKUP
  addressId      String?
  address        Address?         @relation(fields: [addressId], references: [id])
  paymentId      String?          @unique
  payment        Payment?         @relation(fields: [paymentId], references: [id])
  orderItems     OrderItem[]
  statusLogs     OrderStatusLog[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id])
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  quantity   Int
  price      Decimal
  notes      String?
  addons     Json?    // Store selected addons as JSON
}

model OrderStatusLog {
  id        String      @id @default(uuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id])
  status    OrderStatus
  staffId   String?
  staff     Staff?      @relation(fields: [staffId], references: [id])
  createdAt DateTime    @default(now())
}

model Payment {
  id            String   @id @default(uuid())
  order         Order?
  method        String   // UPI, CARD, CASH, IN_APP
  status        String   @default("PENDING") // PENDING, COMPLETED, FAILED
  transactionId String?
  amount        Decimal
  createdAt     DateTime @default(now())
}

model Staff {
  id           String           @id @default(uuid())
  name         String
  email        String           @unique
  password     String
  role         Role
  restaurantId String?
  restaurant   Restaurant?      @relation(fields: [restaurantId], references: [id])
  statusLogs   OrderStatusLog[]
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model Printer {
  id           String     @id @default(uuid())
  name         String
  type         String     // LAN, USB, BLUETOOTH
  connection   String     // IP address, USB port, etc.
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  usage        String     // KITCHEN, BILLING
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Favorite {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
}

model Review {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
}

model Banner {
  id        String   @id @default(uuid())
  title     String
  image     String
  link      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Inventory {
  id        String   @id @default(uuid())
  itemName  String   @unique
  quantity  Float
  unit      String   // kg, l, pcs
  updatedAt DateTime @updatedAt
}

model Settings {
  id                String   @id @default("global")
  restaurantName    String   @default("Gourmet Kitchen")
  contactPhone      String   @default("+1 (555) 000-1111")
  businessEmail     String   @default("hello@gourmetkitchen.com")
  storeAddress      String   @default("123 Culinary Ave, Foodie City, FC 54321")
  acceptingOrders   Boolean  @default(true)
  pushNotifications Boolean  @default(true)
  updatedAt         DateTime @updatedAt
}

model Coupon {
  id          String   @id @default(uuid())
  code        String   @unique
  discount    Float    // percentage or fixed
  expiryDate  DateTime
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
