generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  ADMIN
  MANAGER
  CHEF
  WAITER
  DELIVERY
}

enum OrderStatus {
  NEW_ORDER
  ACCEPTED
  PREPARING
  READY
  SERVED
  COMPLETED
  CANCELLED
}

model User {
  id            String    @id @default(uuid())
  phone         String?   @unique
  email         String?   @unique
  password      String
  name          String?
  role          Role      @default(CUSTOMER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  addresses     Address[]
  orders        Order[]
  reviews       Review[]
  favorites     Favorite[]
  reservations  Reservation[]
  notifications Notification[]
}

model Table {
  id           String     @id @default(uuid())
  tableNumber  String
  capacity     Int
  status       String     @default("AVAILABLE") // AVAILABLE, OCCUPIED, RESERVED
  qrCode       String?    // URL or Data for the QR
  orders       Order[]
  reservations Reservation[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([tableNumber])
}

model Address {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  type          String   // Home, Office, Other
  addressLine1  String
  addressLine2  String?
  city          String
  state         String
  zipCode       String
  isDefault     Boolean  @default(false)
  orders        Order[]
}

model MenuCategory {
  id           String     @id @default(uuid())
  name         String
  image        String?
  items        MenuItem[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model MenuItem {
  id              String         @id @default(uuid())
  name            String
  description     String?
  price           Decimal
  image           String?
  isVeg           Boolean        @default(true)
  isVegan         Boolean        @default(false)
  isGlutenFree    Boolean        @default(false)
  isSpicy         Boolean        @default(false)
  preparationTime Int?           // in minutes
  availability    Boolean        @default(true)
  categoryId      String
  category        MenuCategory   @relation(fields: [categoryId], references: [id])
  addons          Addon[]
  orderItems      OrderItem[]
  favorites       Favorite[]
  reviews         Review[]
  recipeIngredients RecipeIngredient[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Addon {
  id         String   @id @default(uuid())
  name       String
  price      Decimal
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
}

model Order {
  id             String           @id @default(uuid())
  orderNumber    Int              @default(autoincrement())
  userId         String?
  user           User?            @relation(fields: [userId], references: [id])
  tableId        String?
  table          Table?           @relation(fields: [tableId], references: [id])
  status         OrderStatus      @default(NEW_ORDER)
  
  subtotal       Decimal          @default(0.0)
  taxAmount      Decimal          @default(0.0)
  deliveryFee    Decimal          @default(0.0)
  discountAmount Decimal          @default(0.0)
  grandTotal     Decimal

  notes          String?
  cancelReason   String?
  deliveryType   String           @default("DINE_IN") // DINE_IN, DELIVERY, PICKUP
  addressId      String?
  address        Address?         @relation(fields: [addressId], references: [id])
  
  payments       Payment[]
  
  orderItems     OrderItem[]
  statusLogs     OrderStatusLog[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id])
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  quantity   Int
  price      Decimal
  notes      String?
  addons     Json?    // Store selected addons as JSON
}

model OrderStatusLog {
  id        String      @id @default(uuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id])
  status    OrderStatus
  staffId   String?
  staff     Staff?      @relation(fields: [staffId], references: [id])
  createdAt DateTime    @default(now())
}

model Payment {
  id            String   @id @default(uuid())
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id])
  method        String   // UPI, CARD, CASH, IN_APP
  status        String   @default("PENDING") // PENDING, COMPLETED, FAILED
  transactionId String?
  amount        Decimal
  createdAt     DateTime @default(now())
}

model Staff {
  id           String           @id @default(uuid())
  name         String
  email        String           @unique
  password     String
  role         Role
  statusLogs   OrderStatusLog[]
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model Printer {
  id           String     @id @default(uuid())
  name         String
  type         String     // LAN, USB, BLUETOOTH
  connection   String     // IP address, USB port, etc.
  usage        String     // KITCHEN, BILLING
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Favorite {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
}

model Review {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
}

model Banner {
  id        String   @id @default(uuid())
  title     String
  image     String
  link      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Inventory {
  id        String   @id @default(uuid())
  itemName  String   @unique
  quantity  Float
  unit      String   // kg, l, pcs
  recipeIngredients RecipeIngredient[]
  updatedAt DateTime @updatedAt
}

model Settings {
  id                String   @id @default("global")
  restaurantName    String   @default("Gourmet Kitchen")
  contactPhone      String   @default("+1 (555) 000-1111")
  businessEmail     String   @default("hello@gourmetkitchen.com")
  storeAddress      String   @default("123 Culinary Ave, Foodie City, FC 54321")
  
  latitude          Float?   
  longitude         Float?   
  deliveryRadiusKm  Float    @default(5.0)
  minOrderValue     Decimal  @default(0.0)
  
  currency          String   @default("INR") // e.g., INR, USD
  taxRate           Float    @default(5.0)   // e.g., 5% GST
  taxId             String?  // FSSAI or GSTIN for bills
  
  isOpen            Boolean  @default(true)  // Can users place orders RIGHT NOW?
  acceptingOrders   Boolean  @default(true)
  pushNotifications Boolean  @default(true)
  logo              String?  
  
  updatedAt         DateTime @updatedAt
}

model Coupon {
  id          String   @id @default(uuid())
  code        String   @unique
  discount    Float    // percentage or fixed
  expiryDate  DateTime
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RecipeIngredient {
  id           String    @id @default(uuid())
  menuItemId   String
  menuItem     MenuItem  @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  inventoryId  String
  inventory    Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  quantity     Float     // e.g., 0.1 kg, 2 pieces
  createdAt    DateTime  @default(now())
}

model Reservation {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  tableId        String?
  table          Table?   @relation(fields: [tableId], references: [id])
  date           DateTime 
  time           String   // e.g., "19:00"
  partySize      Int
  status         String   @default("PENDING") // PENDING, CONFIRMED, CANCELLED, COMPLETED
  specialRequest String?
  rejectionReason String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String   // RESERVATION, ORDER, PROMO
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
model OTP {
  id        String   @id @default(uuid())
  phone     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}
